# Uploaded to Cloud Build for `gcloud run deploy --source .`.
# The Dockerfile builds the frontend, so node_modules/dist are rebuilt in-image.
.git/
.gitignore
node_modules/
dist/
# Backend deploy is API-only; the frontend ships to GitHub Pages via Actions.
frontend/
**/__pycache__/
**/*.pyc
.venv/
venv/
.env
.env.*
!.env.example
.DS_Store
.claude/
_decoded_*
