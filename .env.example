# Hakam environment — copy to .env for local dev (.env is gitignored)

# --- Google Cloud (production / real Firestore + GCS) ---
GOOGLE_CLOUD_PROJECT=hakam-501212
HAKAM_REGION=me-central1
HAKAM_AUDIO_BUCKET=hakam-audio

# --- Local development ---
# HAKAM_LOCAL=1 uses a file-backed store + local-disk audio, so you can run the
# full Phase-1 flow with NO GCP credentials. Leave UNSET in production so the app
# uses Firestore (room state) and GCS (audio) as required by the architecture.
HAKAM_LOCAL=1

# Debate format (server-authoritative)
HAKAM_TURN_SECONDS=120
HAKAM_ROUNDS_PER_SIDE=2

# Phase 2 only — Gemini key comes from Secret Manager on Cloud Run, .env locally.
# Never referenced by Phase 1 code, never logged, never sent to the frontend.
GEMINI_API_KEY=
